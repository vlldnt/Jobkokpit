# ============================================================================
# Jobkokpit — variables d'environnement
# Copiez ce fichier en `.env` puis remplissez les valeurs :  cp .env.example .env
# Seules les variables de la section "REQUIS" sont nécessaires pour démarrer.
# ============================================================================

# ---------------------------------------------------------------------------
# REQUIS
# ---------------------------------------------------------------------------

# Base de données PostgreSQL.
# Prêt à l'emploi avec le Postgres Docker fourni (docker compose up -d db) :
#   DATABASE_URL="postgresql://jobkokpit:jobkokpit@localhost:5434/jobkokpit"
DATABASE_URL="postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE_NAME>"

# Identifiants du conteneur Postgres (lus par docker compose).
# Doivent correspondre à DATABASE_URL ci-dessus.
POSTGRES_USER="jobkokpit"
POSTGRES_PASSWORD="jobkokpit"
POSTGRES_DB="jobkokpit"

# Secret de session (min. 32 caractères).      -> openssl rand -base64 32
SESSION_SECRET=""

# Clé de chiffrement, exactement 64 caractères hexadécimaux (32 octets).
#                                               -> openssl rand -hex 32
ENCRYPTION_KEY=""

# Secret pour protéger les endpoints cron (min. 16 caractères). -> openssl rand -hex 16
CRON_SECRET=""

# Compte administrateur créé par le seed (npm run db:seed).
AUTH_BOOTSTRAP_EMAIL="admin@example.com"
# Hash Argon2 du mot de passe.  -> npm run auth:hash -- "VotreMotDePasse"
# Collez ici la ligne renvoyée par la commande.
AUTH_BOOTSTRAP_PASSWORD_HASH=""

# URL publique de l'app (laisser tel quel en local).
APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# OPTIONNEL — IA (OpenRouter)
# Sans clé, l'app fonctionne en mode "mock" (analyses/lettres de démonstration).
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=""
# Modèles (défauts déjà définis dans le code, décommentez pour surcharger).
# AI_MODEL_DEFAULT="mistralai/mistral-small-2603"
# AI_MODEL_COMPLEX="mistralai/mistral-small-2603"

# ---------------------------------------------------------------------------
# OPTIONNEL — Sources d'offres d'emploi
# Chaque source s'active dès que sa/ses clé(s) sont renseignées. Aucune n'est
# obligatoire (Remotive, Jobicy et Arbeitnow fonctionnent déjà sans clé).
# ---------------------------------------------------------------------------

# Adzuna (agrégateur FR) — https://developer.adzuna.com
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""

# Careerjet (agrégateur, API v4) — https://www.careerjet.com/partners/api/
CAREERJET_API_KEY=""

# Findwork.dev (offres tech, remote) — https://findwork.dev/developers/
FINDWORK_API_KEY=""

# Jooble (agrégateur multi-pays) — https://jooble.org/api/about
JOOBLE_API_KEY=""

# France Travail (ex-Pôle emploi) — https://francetravail.io
FRANCE_TRAVAIL_CLIENT_ID=""
FRANCE_TRAVAIL_CLIENT_SECRET=""
